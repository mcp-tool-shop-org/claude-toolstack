#!/usr/bin/env bash
# cts-docker — Run cts commands inside the Docker stack.
#
# Usage:
#   cts-docker doctor
#   cts-docker perf --format json
#   cts-docker search "auth" --repo org/repo
#
# Equivalent to: docker compose run --rm toolstack cts "$@"
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_DIR="$(dirname "$SCRIPT_DIR")"

exec docker compose -f "$COMPOSE_DIR/compose.yaml" \
  run --rm toolstack cts "$@"
