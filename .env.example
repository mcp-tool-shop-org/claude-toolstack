# Claude Toolstack — Gateway Configuration
# Copy to .env and customize before deploying

# --- Required ---
API_KEY=change-me-now

# --- Repo access control ---
# Comma-separated org/repo patterns. Supports org/* globs.
ALLOWED_REPOS=myorg/*
DENIED_REPOS=

# --- Paths (container-internal, match compose volumes) ---
REPO_ROOT=/repos
CACHE_ROOT=/cache

# --- Docker socket proxy ---
DOCKER_HOST=tcp://dockerproxy:2375
ALLOWED_CONTAINERS=claude-ctags,claude-build

# --- Search tuning ---
RG_THREADS=4
MAX_MATCHES=200
MAX_RESPONSE_BYTES=524288
REQUEST_TIMEOUT_SEC=20

# --- Concurrency ---
RG_CONCURRENCY=2
JOB_CONCURRENCY=1

# --- Rate limiting ---
RATE_LIMIT_RPS=2
RATE_LIMIT_BURST=10
RATE_LIMIT_SCOPE=key+ip
# Backend: "memory" (single instance) or "redis" (multi-instance, persistent)
RATE_LIMIT_BACKEND=memory
# Only needed if RATE_LIMIT_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0

# --- Audit logging ---
AUDIT_LOG_PATH=/audit/audit.jsonl
AUDIT_LOG_MAX_MB=50
AUDIT_LOG_BACKUPS=5
